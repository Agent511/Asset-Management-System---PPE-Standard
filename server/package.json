{
  "name": "asset-management-backend",
  "version": "1.0.0",
  "description": "Asset Management System Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/scripts/migrate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@yudiel/react-qr-scanner": "^2.6.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react-qr-reader": "^3.0.0-beta-1",
    "uuid": "^14.0.1"
  },
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src"
  ],
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "nodemon": "^3.1.14",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
